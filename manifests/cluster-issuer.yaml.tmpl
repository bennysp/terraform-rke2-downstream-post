apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: vault-issuer
spec:
  vault:
    server: http://${vault_dns}:8200
    path: pki/sign/${clustername}
    auth:
      kubernetes:
        mountPath: /v1/auth/${vault_k8s_auth_path}
        role: ${vault_role}
        secretRef:
          name: ${vault_sec_ref}
          key: token
